{
  "name": "opencode-assistant",
  "version": "0.19.0",
  "description": "Personal AI assistant on Telegram powered by OpenCode: persistent memory, skills, cron jobs with continue/cancel buttons, voice TTS/STT, and one-command MCP installation.",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "opencode-assistant": "dist/cli.js",
    "opencode-assistant-memory-mcp": "dist/mcp/main.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./cli": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "npm run build && npm start",
    "release:prepare": "node scripts/release-prepare.mjs",
    "release:rc": "node scripts/release-prepare.mjs rc",
    "release:notes:preview": "node scripts/release-notes-preview.mjs",
    "lint": "eslint src --ext .ts --max-warnings=0",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JohanYP/Opencode-Assistant.git"
  },
  "keywords": [
    "opencode",
    "telegram",
    "telegram-bot",
    "ai-assistant",
    "personal-assistant",
    "mcp",
    "grammy",
    "cron"
  ],
  "author": "JohanYP",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/JohanYP/Opencode-Assistant/issues"
  },
  "homepage": "https://github.com/JohanYP/Opencode-Assistant#readme",
  "dependencies": {
    "@google-cloud/text-to-speech": "^6.4.0",
    "@grammyjs/menu": "^1.3.1",
    "@opencode-ai/sdk": "^1.1.21",
    "@speechify/api": "^1.0.1",
    "@types/js-yaml": "^4.0.9",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.2.3",
    "grammy": "^1.39.2",
    "https-proxy-agent": "^7.0.6",
    "js-yaml": "^4.1.1",
    "mdast-util-to-string": "^4.0.0",
    "msedge-tts": "^2.0.5",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "socks-proxy-agent": "^8.0.5",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.0.8",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
